---
import '../styles/global.css'
import 'katex/dist/katex.min.css'
import Header from '../components/Header.astro'
import PostHogInit from '../components/PostHogInit.astro'
import CookieBanner from '../components/analytics/CookieBanner.astro'
import { PUBLIC_POSTHOG_API_KEY } from 'astro:env/client'

interface Props {
  title?: string
}

const { title = 'Scroll Reader' } = Astro.props
const user = Astro.locals.user
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,600;1,6..72,300;1,6..72,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <!--
      Prevent flash of wrong theme: runs synchronously before first paint.
      Reads `ctp-theme` from localStorage and adds the flavor class to <html>.
      'auto' (default, no class) defers to prefers-color-scheme via CSS.
    -->
    <script is:inline>
      ;(function () {
        var t = localStorage.getItem('ctp-theme') || 'auto'
        if (t === 'mocha' || t === 'latte') document.documentElement.classList.add(t)
        document.documentElement.dataset.theme =
          t === 'latte' ? 'light' : t === 'mocha' ? 'dark' : 'auto'
      })()
    </script>
    <PostHogInit apiKey={PUBLIC_POSTHOG_API_KEY} />
  </head>
  <body
    class="min-h-screen bg-ed-surface text-ed-on-surface antialiased"
    data-user-id={user?.id}
    data-user-email={user?.email}
  >
    <Header />
    <slot />
    <CookieBanner />
  </body>
</html>

<script>
  // Theme cycling: auto (system) → latte (light) → mocha (dark) → auto
  const THEMES = ['auto', 'latte', 'mocha'] as const
  type Theme = (typeof THEMES)[number]

  function getTheme(): Theme {
    return (localStorage.getItem('ctp-theme') as Theme) ?? 'auto'
  }

  function applyTheme(theme: Theme): void {
    const html = document.documentElement
    html.classList.remove('latte', 'mocha')
    if (theme !== 'auto') html.classList.add(theme)
    localStorage.setItem('ctp-theme', theme)
    html.dataset.theme =
      theme === 'latte' ? 'light' : theme === 'mocha' ? 'dark' : 'auto'
    updateToggles(theme)
  }

  function updateToggles(theme: Theme): void {
    document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((el) => {
      el.dataset.currentTheme = theme
      el.setAttribute('aria-label', `Theme: ${theme}`)
    })
    // Show icon matching the CURRENT theme
    document.querySelectorAll<HTMLElement>('[data-theme-icon]').forEach((icon) => {
      icon.classList.toggle('hidden', icon.dataset.themeIcon !== theme)
    })
  }

  function initToggles(): void {
    document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((el) => {
      el.addEventListener('click', () => {
        const idx = THEMES.indexOf(getTheme())
        applyTheme(THEMES[(idx + 1) % THEMES.length])
      })
    })
    updateToggles(getTheme())
  }

  initToggles()
</script>
