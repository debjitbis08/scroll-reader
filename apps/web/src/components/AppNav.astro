---
import { Icon } from 'astro-icon/components'
import SearchModal from './SearchModal.tsx'

interface Props {
  active?: 'feed' | 'search' | 'saved'
}

const { active = 'feed' } = Astro.props

const items = [
  { id: 'feed', href: '/feed', icon: 'mdi:cards', label: 'Feed' },
  { id: 'search', href: '#', icon: 'mdi:magnify', label: 'Search' },
  { id: 'saved', href: '/saved', icon: 'mdi:bookmark-outline', label: 'Saved' },
] as const
---

{/* Desktop sidebar */}
<aside class="sticky top-14 hidden h-[calc(100vh-3.5rem)] w-16 shrink-0 flex-col items-center gap-1 border-r border-ed-outline-dim pt-4 md:flex">
  {items.map((item) => (
    item.id === 'search' ? (
      <button
        data-open-search
        class={`flex flex-col items-center gap-0.5 rounded-lg px-3 py-2.5 transition-colors ${
          active === item.id
            ? 'text-ed-primary'
            : 'text-ed-on-surface-muted hover:bg-ed-surface-high hover:text-ed-on-surface-dim'
        }`}
      >
        <Icon name={item.icon} class="size-5" />
        <span class="font-body text-[0.6rem] font-medium">{item.label}</span>
      </button>
    ) : (
      <a
        href={item.href}
        class={`flex flex-col items-center gap-0.5 rounded-lg px-3 py-2.5 transition-colors ${
          active === item.id
            ? 'text-ed-primary'
            : 'text-ed-on-surface-muted hover:bg-ed-surface-high hover:text-ed-on-surface-dim'
        }`}
      >
        <Icon name={item.icon} class="size-5" />
        <span class="font-body text-[0.6rem] font-medium">{item.label}</span>
      </a>
    )
  ))}
</aside>

{/* Mobile bottom nav */}
<nav class="fixed bottom-0 left-0 right-0 z-50 flex items-center justify-around border-t border-ed-outline-dim bg-ed-surface py-2 md:hidden">
  {items.map((item) => (
    item.id === 'search' ? (
      <button
        data-open-search
        class={`flex flex-col items-center gap-0.5 ${
          active === item.id
            ? 'text-ed-primary'
            : 'text-ed-on-surface-muted'
        }`}
      >
        <Icon name={item.icon} class="size-5" />
        <span class="font-body text-[0.6rem] font-medium">{item.label}</span>
      </button>
    ) : (
      <a
        href={item.href}
        class={`flex flex-col items-center gap-0.5 ${
          active === item.id
            ? 'text-ed-primary'
            : 'text-ed-on-surface-muted'
        }`}
      >
        <Icon name={item.icon} class="size-5" />
        <span class="font-body text-[0.6rem] font-medium">{item.label}</span>
      </a>
    )
  ))}
</nav>

{/* Bottom spacer for mobile nav */}
<div class="h-16 md:hidden" />

<SearchModal client:load />

<script>
  document.querySelectorAll('[data-open-search]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const trigger = document.querySelector<HTMLButtonElement>('[data-search-trigger]')
      trigger?.click()
    })
  })
</script>
