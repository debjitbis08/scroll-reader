---
import { Icon } from 'astro-icon/components'

const user = Astro.locals.user
---

<header class="sticky top-0 z-50 border-b border-ctp-surface0/50 bg-ctp-base/80 backdrop-blur-lg">
  <div class="flex items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2">
      <Icon name="fa6-solid:scroll" class="size-5 text-ctp-mauve" />
      <span class="text-lg font-semibold tracking-tight">Scroll Reader</span>
    </a>
    <div class="flex items-center gap-2">
      {user && (
        <>
          <a href="/library" class="text-sm text-ctp-subtext0 hover:text-ctp-text">Library</a>
          <a
            href="/upload"
            class="flex items-center gap-1.5 rounded-lg bg-ctp-mauve px-3 py-1.5 text-sm font-medium text-ctp-base transition-colors hover:bg-ctp-mauve/80"
          >
            <Icon name="mdi:plus" class="size-4" />
            Upload
          </a>
          <form method="POST" action="/api/auth/logout">
            <button
              type="submit"
              class="rounded-md p-2 text-ctp-subtext0 transition-colors hover:bg-ctp-surface0 hover:text-ctp-text"
              title="Log out"
            >
              <Icon name="mdi:logout" class="size-5" />
            </button>
          </form>
        </>
      )}
      <button
        data-theme-toggle
        class="rounded-md p-2 text-ctp-subtext0 transition-colors hover:bg-ctp-surface0 hover:text-ctp-text"
      >
        <Icon name="fa6-solid:sun" class="size-5 theme-icon hidden" data-theme-icon="latte" />
        <Icon name="fa6-solid:moon" class="size-5 theme-icon hidden" data-theme-icon="mocha" />
        <Icon name="fa6-solid:desktop" class="size-5 theme-icon" data-theme-icon="auto" />
      </button>
    </div>
  </div>
</header>
