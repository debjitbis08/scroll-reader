---
import Layout from '../../layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { eq, and, sql, count, inArray, gte } from 'drizzle-orm'
import { db } from '../../lib/db.ts'
import { documents, chunks, cards, jobs, cardScores, feedEvents, collectionDocuments, usageEvents, profiles } from '@scroll-reader/db'
import CollectionManager from '../../components/CollectionManager.tsx'
import type { DocumentType, ReadingGoal, Tier } from '@scroll-reader/shared-types'
import { resolveCardStrategy, describeStrategy, TIER_LIMITS } from '@scroll-reader/shared-types'
import { ADMIN_EMAILS } from 'astro:env/server'
import { createSupabaseServer } from '../../lib/supabase.ts'
import AdminGenerate from '../../components/AdminGenerate.tsx'
import JobPoller from '../../components/JobPoller.tsx'
import PageRangeSelector from '../../components/PageRangeSelector.tsx'
import LatexText from '../../components/LatexText.tsx'
import FlashcardRenderer from '../../components/cards/FlashcardRenderer.tsx'
import QuizRenderer from '../../components/cards/QuizRenderer.tsx'
import GlossaryRenderer from '../../components/cards/GlossaryRenderer.tsx'
import ContrastRenderer from '../../components/cards/ContrastRenderer.tsx'
import PassageRenderer from '../../components/cards/PassageRenderer.tsx'
import type { BodyContent, FlashcardContent, QuizContent, GlossaryContent, ContrastContent, PassageContent } from '@scroll-reader/shared-types'

if (!Astro.locals.user) return Astro.redirect('/login')

const supabase = createSupabaseServer(Astro.request, Astro.cookies)
const { data: { user: supaUser } } = await supabase.auth.getUser()
const adminEmails = new Set(
  ADMIN_EMAILS.split(',').map((e) => e.trim().toLowerCase()).filter(Boolean),
)
const isAdmin = !!supaUser?.email && adminEmails.has(supaUser.email.toLowerCase())

const userId = Astro.locals.user.id
const docId = Astro.params.id!

// Load document (verify ownership)
const [doc] = await db
  .select()
  .from(documents)
  .where(and(eq(documents.id, docId), eq(documents.userId, userId)))
  .limit(1)

if (!doc) return Astro.redirect('/library')

// Collection memberships for this document
const docCollectionRows = await db
  .select({ collectionId: collectionDocuments.collectionId })
  .from(collectionDocuments)
  .where(eq(collectionDocuments.documentId, docId))
const docCollectionIds = docCollectionRows.map((r) => r.collectionId)

// Load most recent job for this document
const [job] = await db
  .select()
  .from(jobs)
  .where(and(eq(jobs.documentId, docId), eq(jobs.userId, userId)))
  .orderBy(jobs.createdAt)
  .limit(1)

const isPending = doc.processingStatus === 'pending'
const isPreview = doc.processingStatus === 'preview'
const isChunking = doc.processingStatus === 'chunking'
const isGenerating = doc.processingStatus === 'generating'
const isReady = doc.processingStatus === 'ready'
const isError = doc.processingStatus === 'error'
const isRetrying = (isChunking || isGenerating) && (doc.retryCount ?? 0) > 0
const hasChunks = !isPending && !isPreview && !isError

const strategy = resolveCardStrategy(
  (doc.documentType ?? 'other') as DocumentType,
  (doc.readingGoal ?? 'reflective') as ReadingGoal,
)

// --- Daily quota ---
const [profileRow] = await db
  .select({ tier: profiles.tier })
  .from(profiles)
  .where(eq(profiles.id, userId))
  .limit(1)

const userTier = (profileRow?.tier ?? 'free') as Tier
const dailyLimit = TIER_LIMITS[userTier].cardsPerDay

const todayStart = new Date()
todayStart.setUTCHours(0, 0, 0, 0)
const [quotaRow] = await db
  .select({ total: sql<number>`coalesce(sum(${usageEvents.quantity}), 0)::int` })
  .from(usageEvents)
  .where(and(
    eq(usageEvents.userId, userId),
    eq(usageEvents.eventType, 'cards_generated'),
    gte(usageEvents.occurredAt, todayStart),
  ))
const cardsToday = quotaRow?.total ?? 0
const quotaExhausted = cardsToday >= dailyLimit

const resetAt = new Date()
resetAt.setUTCHours(24, 0, 0, 0)

// --- Data queries (only when we have chunks/cards) ---

type CardRow = typeof cards.$inferSelect
type ChunkRow = typeof chunks.$inferSelect

let allChunks: ChunkRow[] = []
let totalTextChunks = 0
let cardTypeCounts: Record<string, number> = {}
let chunksWithCards = 0
let seenChunkIndices = new Set<number>()
let masteredChunkIndices = new Set<number>()
let estimatedTotalChunks: number | null = null
type SampleCard = { card: CardRow; chunk: ChunkRow }
let sampleCards: SampleCard[] = []
let chunkIndicesWithCards = new Set<number>()
// Processing map: cap real dots at 500 to avoid perf issues on huge books
const MAP_MAX_DOTS = 500
let mapTextChunks: ChunkRow[] = []
let mapSampledChunks: ChunkRow[] = []
let mapEstimatedRemaining = 0

if (hasChunks) {
  // Load all chunks (needed for processing map + chunk estimation)
  allChunks = await db
    .select()
    .from(chunks)
    .where(and(eq(chunks.documentId, docId), eq(chunks.userId, userId)))
    .orderBy(chunks.chunkIndex)

  totalTextChunks = allChunks.filter((c) => c.chunkType === 'text' || c.chunkType === 'code').length

  // Card type counts + chunks with cards (aggregates only, no full card rows)
  const typeCountRows = await db
    .select({
      cardType: cards.cardType,
      count: sql<number>`count(*)::int`,
    })
    .from(cards)
    .innerJoin(chunks, eq(cards.chunkId, chunks.id))
    .where(and(eq(cards.userId, userId), eq(chunks.documentId, docId)))
    .groupBy(cards.cardType)

  for (const row of typeCountRows) {
    cardTypeCounts[row.cardType] = row.count
  }

  // Count distinct chunks that have cards
  const [cwcRow] = await db
    .select({ count: sql<number>`count(distinct ${cards.chunkId})::int` })
    .from(cards)
    .innerJoin(chunks, eq(cards.chunkId, chunks.id))
    .where(and(eq(cards.userId, userId), eq(chunks.documentId, docId)))
  chunksWithCards = cwcRow?.count ?? 0

  // Which chunk indices have cards (for processing map)
  const chunkIdxRows = await db
    .select({ chunkIndex: chunks.chunkIndex })
    .from(cards)
    .innerJoin(chunks, eq(cards.chunkId, chunks.id))
    .where(and(eq(cards.userId, userId), eq(chunks.documentId, docId)))
    .groupBy(chunks.chunkIndex)
  chunkIndicesWithCards = new Set(chunkIdxRows.map((r) => r.chunkIndex))

  // Sample cards: one per type via DISTINCT ON
  const sampleRows = await db.execute<{
    card_id: string; card_type: string; content: Record<string, unknown>;
    encrypted: boolean; ai_provider: string | null; ai_model: string | null;
    chunk_id: string; chunk_content: string; chunk_type: string;
    chunk_index: number; chapter: string | null; word_count: number | null;
    language: string | null;
  }>(sql`
    SELECT DISTINCT ON (c.card_type)
      c.id AS card_id, c.card_type, c.content, c.encrypted,
      c.ai_provider, c.ai_model,
      ch.id AS chunk_id, ch.content AS chunk_content, ch.chunk_type,
      ch.chunk_index, ch.chapter, ch.word_count, ch.language
    FROM cards c
    JOIN chunks ch ON c.chunk_id = ch.id
    WHERE c.user_id = ${userId} AND ch.document_id = ${docId}
    ORDER BY c.card_type, c.created_at DESC
  `)

  sampleCards = sampleRows.map((r) => ({
    card: {
      id: r.card_id,
      cardType: r.card_type,
      content: typeof r.content === 'string' ? JSON.parse(r.content) : r.content,
      encrypted: r.encrypted,
      aiProvider: r.ai_provider,
      aiModel: r.ai_model,
      // fields not needed for rendering
      userId, chunkId: r.chunk_id, secondaryChunkId: null, createdAt: null,
    } as CardRow,
    chunk: {
      id: r.chunk_id,
      content: r.chunk_content,
      chunkType: r.chunk_type,
      chunkIndex: r.chunk_index,
      chapter: r.chapter,
      wordCount: r.word_count,
      language: r.language,
      // fields not needed for rendering
      userId, documentId: docId, encrypted: false, createdAt: null,
    } as ChunkRow,
  }))

  // Reading progress: distinct chunk indices seen via feed events
  const seenRows = await db
    .select({ chunkIndex: chunks.chunkIndex })
    .from(feedEvents)
    .innerJoin(cards, eq(feedEvents.cardId, cards.id))
    .innerJoin(chunks, eq(cards.chunkId, chunks.id))
    .where(and(
      eq(feedEvents.userId, userId),
      eq(chunks.documentId, docId),
    ))
    .groupBy(chunks.chunkIndex)

  seenChunkIndices = new Set(seenRows.map((r) => r.chunkIndex))

  // Mastered chunks: chunk indices where at least one card has srRepetition >= 3
  const masteredRows = await db
    .select({ chunkIndex: chunks.chunkIndex })
    .from(cardScores)
    .innerJoin(cards, eq(cardScores.cardId, cards.id))
    .innerJoin(chunks, eq(cards.chunkId, chunks.id))
    .where(and(
      eq(cardScores.userId, userId),
      eq(chunks.documentId, docId),
      sql`${cardScores.srRepetition} >= 3`,
    ))
    .groupBy(chunks.chunkIndex)

  masteredChunkIndices = new Set(masteredRows.map((r) => r.chunkIndex))

  // Chunk estimation
  if (isReady) {
    estimatedTotalChunks = totalTextChunks
  } else if (totalTextChunks > 0 && doc.totalPages && doc.pageStart && doc.pageEnd) {
    const selectedPages = doc.pageEnd - doc.pageStart + 1
    const processedPages = doc.elementsProcessed && doc.totalElements
      ? Math.round(selectedPages * (doc.elementsProcessed / doc.totalElements))
      : 0
    if (processedPages > 0) {
      estimatedTotalChunks = Math.round(totalTextChunks * (selectedPages / processedPages))
    }
  }

  // Processing map computation (kept in frontmatter to avoid JSX parser issues with < operator)
  mapTextChunks = allChunks.filter((c) => c.chunkType === 'text' || c.chunkType === 'code')
  const mapTotal = estimatedTotalChunks ?? mapTextChunks.length
  mapEstimatedRemaining = Math.max(0, mapTotal - mapTextChunks.length)
  if (mapTextChunks.length <= MAP_MAX_DOTS) {
    mapSampledChunks = mapTextChunks
  } else {
    mapSampledChunks = mapTextChunks.filter((_, i) =>
      Math.floor((i * MAP_MAX_DOTS) / mapTextChunks.length) !== Math.floor(((i - 1) * MAP_MAX_DOTS) / mapTextChunks.length)
    )
  }
}

// Format helpers
const READING_GOAL_LABEL: Record<string, string> = {
  casual: 'Casual',
  reflective: 'Reflective',
  study: 'Study',
}
const DOC_TYPE_LABEL: Record<string, string> = {
  book: 'Book', paper: 'Paper', article: 'Article', manual: 'Textbook',
  note: 'Note', scripture: 'Scripture', other: 'Other', fiction: 'Fiction',
}
const CARD_TYPE_LABEL: Record<string, string> = {
  discover: 'Discover', raw_commentary: 'Notes', flashcard: 'Flashcard',
  quiz: 'Quiz', glossary: 'Glossary', contrast: 'Contrast', passage: 'Passage',
}
const PRIORITY_LABEL: Record<string, string> = {
  pinned: 'Pinned', active: 'Active', normal: 'Normal',
}

const uploadDate = doc.createdAt ? new Date(doc.createdAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
}) : null

const totalCards = Object.values(cardTypeCounts).reduce((a, b) => a + b, 0)

// Tonal hues for card type distribution chart — need to be visually distinct
// These are inline styles so they work in both light/dark without extra CSS vars
const CARD_TYPE_HUE: Record<string, string> = {
  discover: '#6b8e5a',     // muted green
  raw_commentary: '#7a8b6e', // sage
  flashcard: '#b8956a',    // warm amber
  quiz: '#8a7ab5',         // soft purple
  glossary: '#b5a045',     // ochre
  contrast: '#5a8a8a',     // teal
  passage: '#a06a6a',      // dusty rose
}
---

<Layout title={`${doc.title} — Scroll Reader`}>
  <div class="mx-auto max-w-3xl space-y-8 px-4 py-8 md:py-12">

    <!-- Back link -->
    <a href="/library" class="inline-flex items-center gap-1.5 font-body text-[0.75rem] tracking-wide text-ed-on-surface-muted hover:text-ed-primary transition-colors">
      <Icon name="mdi:arrow-left" class="size-4" />
      Library
    </a>

    <!-- Header: title + quick actions -->
    <div class="flex flex-col md:flex-col items-start justify-between gap-4">
      <div class="min-w-0">
        <div id="title-display">
          <h1 class="font-display text-xl md:text-3xl leading-tight text-ed-on-surface">{doc.title}</h1>
        </div>
        <div class="hidden items-center gap-2" id="title-edit">
          <input
            type="text"
            id="title-input"
            value={doc.title}
            class="font-display text-3xl leading-tight text-ed-on-surface bg-transparent border-b-2 border-ed-primary outline-none w-full min-w-0"
          />
          <button data-action="save-title" data-doc-id={doc.id} class="rounded p-1.5 text-ed-primary hover:bg-ed-surface-high transition-colors shrink-0" title="Save">
            <Icon name="mdi:check" class="size-5" />
          </button>
          <button data-action="cancel-title" class="rounded p-1.5 text-ed-on-surface-muted hover:bg-ed-surface-high transition-colors shrink-0" title="Cancel">
            <Icon name="mdi:close" class="size-5" />
          </button>
        </div>
        {doc.author && <p class="mt-1 font-body text-sm text-ed-on-surface-dim">{doc.author}</p>}
      </div>
      <div class="flex items-center gap-1 shrink-0">
        <button
          data-action="edit-title"
          data-doc-id={doc.id}
          class="rounded p-2 text-ed-on-surface-muted transition-colors hover:bg-ed-surface-high hover:text-ed-primary"
          title="Edit title"
        >
          <Icon name="mdi:pencil-outline" class="size-5" />
        </button>
        {(isChunking || isGenerating) && !doc.paused && (
          <button
            data-action="pause"
            data-doc-id={doc.id}
            class="rounded p-2 text-ed-on-surface-muted transition-colors hover:bg-ed-surface-high hover:text-ed-primary"
            title="Pause card generation"
          >
            <Icon name="mdi:pause-circle-outline" class="size-5" />
          </button>
        )}
        {doc.paused && (
          <button
            data-action="resume"
            data-doc-id={doc.id}
            class="rounded p-2 text-ed-primary transition-colors hover:bg-ed-surface-high"
            title="Resume card generation"
          >
            <Icon name="mdi:play-circle-outline" class="size-5" />
          </button>
        )}
        <button
          data-action="delete"
          data-doc-id={doc.id}
          class="rounded p-2 text-ed-on-surface-muted transition-colors hover:bg-ed-surface-high hover:text-ed-on-surface"
          title="Delete document"
        >
          <Icon name="mdi:delete-outline" class="size-5" />
        </button>
      </div>
    </div>

    <!-- Document metadata (hidden during preview — configure section shows these) -->
    {!isPreview && <div class="flex flex-wrap gap-x-4 gap-y-1 font-body text-[0.75rem] tracking-wide text-ed-on-surface-muted">
      <span>{DOC_TYPE_LABEL[doc.documentType] ?? doc.documentType}</span>
      {doc.readingGoal && (
        <span class="flex items-center gap-1">
          <Icon name="mdi:target" class="size-3.5" />
          {READING_GOAL_LABEL[doc.readingGoal]}
        </span>
      )}
      {doc.totalPages && !doc.toc && (
        <span class="flex items-center gap-1">
          <Icon name="mdi:book-open-page-variant-outline" class="size-3.5" />
          {doc.pageStart && doc.pageEnd && doc.pageEnd !== doc.totalPages
            ? `pp. ${doc.pageStart}-${doc.pageEnd} of ${doc.totalPages}`
            : `${doc.totalPages} pages`
          }
        </span>
      )}
      {doc.toc && doc.selectedTocIndices && (
        <span class="flex items-center gap-1">
          <Icon name="mdi:book-open-page-variant-outline" class="size-3.5" />
          {(doc.selectedTocIndices as number[]).length} of {(doc.toc as unknown[]).length} chapters selected
        </span>
      )}
      {doc.toc && !doc.selectedTocIndices && (
        <span class="flex items-center gap-1">
          <Icon name="mdi:book-open-page-variant-outline" class="size-3.5" />
          {(doc.toc as unknown[]).length} chapters
        </span>
      )}
      {doc.source === 'upload' && (
        <span class="flex items-center gap-1">
          <Icon name="mdi:cloud-upload-outline" class="size-3.5" />
          Uploaded
        </span>
      )}
      {uploadDate && (
        <span class="flex items-center gap-1">
          <Icon name="mdi:calendar-outline" class="size-3.5" />
          {uploadDate}
        </span>
      )}
      <span class="flex items-start gap-1 mt-2">
        <Icon name="mdi:cards-outline" class="size-3.5" />
        {describeStrategy(strategy)}
      </span>
    </div>}

    <!-- Collections -->
    <div class="mb-2">
        <CollectionManager
        documentId={docId}
        initialCollectionIds={docCollectionIds}
        client:load
        />
    </div>

    <!-- Priority control -->
    {hasChunks && (
      <div class="mt-2">
        <div class="flex items-center gap-2">
          <span class="font-body text-sm tracking-wide text-ed-on-surface-muted">Priority:</span>
          <div class="border border-ed-outline-dim p-1 rounded">
            {(['pinned', 'active', 'normal'] as const).map((p) => (
              <button
                data-action="priority"
                data-doc-id={doc.id}
                data-priority={p}
                class:list={[
                  'rounded px-3 py-0.5 font-body text-sm font-medium tracking-wide transition-colors',
                  doc.priority === p
                    ? 'bg-ed-surface-highest text-ed-primary'
                    : 'text-ed-on-surface-muted hover:bg-ed-surface-high',
                ]}
              >
                {p === 'pinned' && <Icon name="mdi:pin" class="size-3 inline -mt-0.5 mr-0.5" />}
                {PRIORITY_LABEL[p]}
              </button>
            ))}
          </div>
        </div>
        <p class="font-body text-xs text-ed-on-surface-muted mt-2">
          Cards are generated daily across all your documents. Priority controls which documents get processed first when your daily budget is limited.
        </p>
      </div>
    )}

    <!-- Pending: extracting page count -->
    {isPending && (
      <JobPoller jobId={job?.id ?? ''} client:load />
    )}

    <!-- Preview: page range selector -->
    {isPreview && doc.totalPages && (
      <PageRangeSelector
        docId={doc.id}
        totalPages={doc.totalPages}
        initialStart={doc.pageStart ?? 1}
        initialEnd={doc.pageEnd ?? doc.totalPages}
        toc={doc.toc ?? undefined}
        client:load
      />
    )}

    <!-- Retrying after transient error -->
    {isRetrying && (
      <div class="rounded bg-ed-surface-high px-6 py-4">
        <p class="font-body text-sm font-medium text-ed-on-surface">Temporarily failed, retrying automatically…</p>
        {job?.error && <p class="mt-1 font-body text-sm text-ed-on-surface-dim opacity-80">{job.error}</p>}
        <p class="mt-1 font-body text-xs text-ed-on-surface-muted">Attempt {doc.retryCount} of 3</p>
      </div>
    )}

    <!-- Permanent error state -->
    {isError && (
      <div class="rounded bg-ed-surface-high px-6 py-4">
        <p class="font-body text-sm font-medium text-ed-on-surface">Processing failed</p>
        {job?.error && <p class="mt-1 font-body text-sm text-ed-on-surface-dim opacity-80">{job.error}</p>}
        {(doc.retryCount ?? 0) > 0 && (
          <p class="mt-1 font-body text-xs text-ed-on-surface-muted">Failed after {doc.retryCount} retries</p>
        )}
        <a href="/upload" class="mt-3 inline-block font-body text-sm font-medium text-ed-primary underline">
          Try another document
        </a>
      </div>
    )}

    <!-- Hero: Processing map with funnel -->
    {hasChunks && (estimatedTotalChunks ?? totalTextChunks) > 0 && (
      <div class="rounded bg-ed-surface-high p-6 space-y-6">

        <!-- Funnel numbers -->
        <div class="flex items-end justify-between gap-2">
          <div class="flex items-baseline gap-1">
            {(isChunking || isGenerating) && (
              <span class="flex items-center gap-1.5 font-body text-[0.7rem] text-ed-on-surface-muted">
                <span class="size-1.5 rounded-full bg-ed-primary animate-pulse" />
                {doc.paused ? 'Paused' : 'Processing'}
              </span>
            )}
          </div>
          {totalCards > 0 && (
            <span class="font-body text-[0.75rem] text-ed-on-surface-muted">
              {totalCards} card{totalCards !== 1 ? 's' : ''} generated
            </span>
          )}
        </div>

        <div class="grid grid-cols-4 gap-px text-center">
          <div class="space-y-1">
            <p class="font-display text-2xl text-ed-on-surface tabular-nums">{masteredChunkIndices.size}</p>
            <p class="font-body text-[0.65rem] uppercase tracking-[0.15em] text-ed-on-surface-muted">Sections mastered</p>
          </div>
          <div class="space-y-1">
            <p class="font-display text-2xl text-ed-on-surface tabular-nums">{seenChunkIndices.size}</p>
            <p class="font-body text-[0.65rem] uppercase tracking-[0.15em] text-ed-on-surface-muted">Seen in your feed</p>
          </div>
          <div class="space-y-1">
            <p class="font-display text-2xl text-ed-on-surface tabular-nums">{chunksWithCards}</p>
            <p class="font-body text-[0.65rem] uppercase tracking-[0.15em] text-ed-on-surface-muted">Sections processed</p>
          </div>
          <div class="space-y-1">
            <div class="flex items-center justify-center gap-1">
              <p class="font-display text-2xl text-ed-on-surface-dim tabular-nums">
                {isReady ? (estimatedTotalChunks ?? totalTextChunks) : `~${estimatedTotalChunks ?? totalTextChunks}`}
              </p>
              {!isReady && (
                <span
                  class="text-ed-on-surface-muted cursor-help"
                  title="Estimated based on sections extracted so far and total page count"
                >
                  <Icon name="mdi:information-outline" class="size-3.5" />
                </span>
              )}
            </div>
            <p class="font-body text-[0.65rem] uppercase tracking-[0.15em] text-ed-on-surface-muted">
              Sections in book
            </p>
          </div>
        </div>

        <!-- The map -->
        <div class="space-y-1">
          {/* Real chunks as dots — sampled to max 500 */}
          {mapSampledChunks.length > 0 && (
            <div class="flex flex-wrap gap-px">
              {mapSampledChunks.map((chunk) => {
                const isMastered = masteredChunkIndices.has(chunk.chunkIndex)
                const isSeen = seenChunkIndices.has(chunk.chunkIndex)
                const hasCards = chunkIndicesWithCards.has(chunk.chunkIndex)
                return (
                  <div
                    class:list={[
                      'size-2 rounded-sm',
                      isMastered ? 'bg-ed-primary' :
                      isSeen ? 'bg-ed-primary/60' :
                      hasCards ? 'bg-ed-primary-container' :
                      'bg-ed-outline-dim',
                    ]}
                    title={`§${chunk.chunkIndex + 1}${chunk.chapter ? ` — ${chunk.chapter}` : ''}`}
                  />
                )
              })}
            </div>
          )}
          {/* Estimated remaining — single bar with inline label */}
          {mapEstimatedRemaining > 0 && (
            <div
              class="flex items-center px-2 h-4 rounded-sm bg-ed-surface-container"
              style={`width: ${Math.max(8, Math.round((mapEstimatedRemaining / (estimatedTotalChunks ?? totalTextChunks)) * 100))}%`}
            >
              <span class="font-body text-[0.6rem] text-ed-on-surface-muted truncate">
                ~{mapEstimatedRemaining} estimated remaining
              </span>
            </div>
          )}
        </div>

        <!-- Legend -->
        <div class="flex flex-wrap gap-x-4 gap-y-1 font-body text-[0.65rem] text-ed-on-surface-muted">
          <span class="flex items-center gap-1.5">
            <span class="size-2 rounded-sm bg-ed-primary" />
            Mastered
          </span>
          <span class="flex items-center gap-1.5">
            <span class="size-2 rounded-sm bg-ed-primary/60" />
            Seen in feed
          </span>
          <span class="flex items-center gap-1.5">
            <span class="size-2 rounded-sm bg-ed-primary-container" />
            Processed
          </span>
          <span class="flex items-center gap-1.5">
            <span class="size-2 rounded-sm bg-ed-surface-container" />
            Not yet processed
          </span>
        </div>

        <p class="font-body text-[0.7rem] text-ed-on-surface-muted italic">
          Each cell is one section of the book. Your cards are drawn only from the highlighted sections. Each may generate multiple cards.
        </p>

        {totalCards === 0 && (
          <div class="flex items-center justify-between gap-2 rounded bg-ed-surface-container px-3 py-2">
            <div class="space-y-0.5">
              <p class="font-body text-[0.7rem] text-ed-on-surface">
                {quotaExhausted
                  ? <>Daily card limit reached — no cards have been generated for this book yet. Next generation eligible <time id="doc-quota-reset" datetime={resetAt.toISOString()} class="font-medium">{resetAt.toUTCString()}</time>.</>
                  : doc.paused
                  ? 'This document is paused — unpause it to start generating cards.'
                  : <>{cardsToday} of {dailyLimit} cards generated today across all your documents. Cards for this book are queued.</>}
              </p>
              {!quotaExhausted && !doc.paused && (
                <p class="font-body text-[0.65rem] text-ed-on-surface-muted">Quota resets <time id="doc-quota-reset" datetime={resetAt.toISOString()}>{resetAt.toUTCString()}</time>.</p>
              )}
            </div>
            <div class="flex flex-col items-end gap-0.5 shrink-0">
              <span class="font-display text-sm tabular-nums text-ed-on-surface">{cardsToday}<span class="text-ed-on-surface-muted">/{dailyLimit}</span></span>
              <div class="w-16 h-1 rounded-full bg-ed-outline-dim overflow-hidden">
                <div
                  class:list={['h-full rounded-full', quotaExhausted ? 'bg-ed-error' : 'bg-ed-primary']}
                  style={`width: ${Math.min(100, Math.round((cardsToday / dailyLimit) * 100))}%`}
                />
              </div>
            </div>
          </div>
        )}
      </div>
    )}

    <!-- Card type distribution -->
    {hasChunks && totalCards > 0 && (
      <div class="rounded bg-ed-surface-high p-5 space-y-3">
        <h2 class="font-body text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-ed-primary">Card Types</h2>
        <div class="space-y-2">
          {Object.entries(cardTypeCounts)
            .sort(([, a], [, b]) => b - a)
            .map(([type, count]) => (
              <div class="flex items-center gap-2">
                <span class="size-2 rounded-sm shrink-0" style={`background: ${CARD_TYPE_HUE[type] ?? '#888'}`} />
                <span class="font-body text-sm text-ed-on-surface-dim flex-1">{CARD_TYPE_LABEL[type] ?? type}</span>
                <span class="font-body text-sm font-medium text-ed-on-surface tabular-nums">{count}</span>
              </div>
            ))
          }
        </div>
        <div class="h-1.5 rounded-sm overflow-hidden flex bg-ed-surface-container">
          {Object.entries(cardTypeCounts)
            .sort(([, a], [, b]) => b - a)
            .map(([type, count]) => (
              <div
                class="h-full"
                style={`width: ${(count / totalCards) * 100}%; background: ${CARD_TYPE_HUE[type] ?? '#888'}`}
                title={`${CARD_TYPE_LABEL[type]}: ${count}`}
              />
            ))
          }
        </div>
      </div>
    )}

    <!-- Sample cards: one per type, Feed-style -->
    {hasChunks && sampleCards.length > 0 && (
      <div class="space-y-6">
        <h2 class="font-body text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-ed-primary">
          Sample Cards
        </h2>
        <div class="flex flex-col gap-8">
          {sampleCards.map(({ card, chunk }) => (
            <div>
              <div class="mb-2">
                <span class="font-body text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-ed-primary">
                  {CARD_TYPE_LABEL[card.cardType] ?? card.cardType}
                </span>
              </div>
              <div class={`rounded p-6 ${card.cardType === 'flashcard' ? 'bg-ed-surface-dim' : 'bg-ed-surface-high'}`}>
                {card.cardType === 'discover' ? (
                  <div class="space-y-3">
                    {(card.content as BodyContent).title && (
                      <h3 class="font-display text-xl leading-snug text-ed-on-surface">
                        {(card.content as BodyContent).title}
                      </h3>
                    )}
                    <LatexText text={(card.content as BodyContent).body ?? ''} class="font-body text-sm leading-relaxed text-ed-on-surface-dim" client:load />
                  </div>
                ) : card.cardType === 'flashcard' ? (
                  <FlashcardRenderer content={card.content as FlashcardContent} client:load />
                ) : card.cardType === 'quiz' ? (
                  <QuizRenderer content={card.content as QuizContent} client:load />
                ) : card.cardType === 'glossary' ? (
                  <GlossaryRenderer content={card.content as GlossaryContent} client:load />
                ) : card.cardType === 'contrast' ? (
                  <ContrastRenderer content={card.content as ContrastContent} client:load />
                ) : card.cardType === 'passage' ? (
                  <PassageRenderer content={card.content as PassageContent} client:load />
                ) : (
                  <LatexText text={(card.content as BodyContent).body ?? ''} class="font-display text-[0.95rem] leading-relaxed text-ed-on-surface" client:load />
                )}
                {chunk.chapter && (
                  <div class="mt-4 flex items-center gap-1.5 text-ed-on-surface-muted">
                    <svg class="size-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                    </svg>
                    <span class="truncate font-body text-[0.65rem] tracking-wide">{chunk.chapter}</span>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {isReady && sampleCards.length === 0 && (
      <div class="rounded bg-ed-surface-high px-6 py-5 text-center space-y-1">
        {strategy.cardTypes.length === 0 ? (
          <>
            <p class="font-display text-lg text-ed-on-surface">Reading mode</p>
            <p class="font-body text-sm text-ed-on-surface-muted">No cards for this document — just reading.</p>
          </>
        ) : (
          <p class="font-body text-sm text-ed-on-surface-muted">No cards generated for this document.</p>
        )}
      </div>
    )}

    {/* Admin: generate cards bypassing daily limits */}
    {isAdmin && (isChunking || isGenerating) && !doc.paused && (
      <AdminGenerate documentId={docId} client:load />
    )}
  </div>
</Layout>

<script>
  // Localize quota reset time to user's timezone
  const resetEl = document.getElementById('doc-quota-reset')
  if (resetEl) {
    const dt = new Date(resetEl.getAttribute('datetime')!)
    const now = new Date()
    const isToday = dt.toDateString() === now.toDateString()
    const time = dt.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' })
    resetEl.textContent = isToday ? `today at ${time}` : `tomorrow at ${time}`
  }

  // Edit title
  const titleDisplay = document.getElementById('title-display')!
  const titleEdit = document.getElementById('title-edit')!
  const titleInput = document.getElementById('title-input') as HTMLInputElement

  function startEditing() {
    titleDisplay.classList.add('hidden')
    titleEdit.classList.remove('hidden')
    titleEdit.classList.add('flex')
    titleInput.focus()
    titleInput.select()
  }

  function stopEditing() {
    titleEdit.classList.add('hidden')
    titleEdit.classList.remove('flex')
    titleDisplay.classList.remove('hidden')
  }

  document.querySelector('[data-action="edit-title"]')?.addEventListener('click', startEditing)
  document.querySelector('[data-action="cancel-title"]')?.addEventListener('click', () => {
    titleInput.value = titleDisplay.querySelector('h1')!.textContent!
    stopEditing()
  })

  async function saveTitle() {
    const docId = document.querySelector<HTMLElement>('[data-action="save-title"]')!.dataset.docId
    const newTitle = titleInput.value.trim()
    if (!newTitle) return
    const res = await fetch(`/api/documents/${docId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title: newTitle }),
    })
    if (res.ok) {
      titleDisplay.querySelector('h1')!.textContent = newTitle
      document.title = `${newTitle} — Scroll Reader`
      stopEditing()
    } else {
      alert('Failed to update title.')
    }
  }

  document.querySelector('[data-action="save-title"]')?.addEventListener('click', saveTitle)
  titleInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') saveTitle()
    if (e.key === 'Escape') {
      titleInput.value = titleDisplay.querySelector('h1')!.textContent!
      stopEditing()
    }
  })

  // Delete
  document.querySelector('[data-action="delete"]')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLElement
    const docId = btn.dataset.docId
    if (!confirm('Delete this document and all its cards?')) return
    const res = await fetch(`/api/documents/${docId}`, { method: 'DELETE' })
    if (res.ok) window.location.href = '/library'
    else alert('Failed to delete document.')
  })

  // Pause / Resume
  for (const btn of document.querySelectorAll('[data-action="pause"], [data-action="resume"]')) {
    btn.addEventListener('click', async (e) => {
      const el = e.currentTarget as HTMLElement
      const docId = el.dataset.docId
      const action = el.dataset.action // 'pause' or 'resume'
      const res = await fetch(`/api/documents/${docId}/pause`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paused: action === 'pause' }),
      })
      if (res.ok) window.location.reload()
      else alert(`Failed to ${action} processing.`)
    })
  }

  // Priority
  for (const btn of document.querySelectorAll('[data-action="priority"]')) {
    btn.addEventListener('click', async (e) => {
      const el = e.currentTarget as HTMLElement
      const docId = el.dataset.docId
      const priority = el.dataset.priority
      const res = await fetch(`/api/documents/${docId}/priority`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ priority }),
      })
      if (res.ok) window.location.reload()
      else alert('Failed to update priority.')
    })
  }
</script>
