---
import Layout from '../../layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { eq, and } from 'drizzle-orm'
import { db } from '../../lib/db.ts'
import { documents, chunks, cards, jobs } from '@scroll-reader/db'
import type { CardStrategy } from '@scroll-reader/shared-types'
import JobPoller from '../../components/JobPoller.tsx'
import AutoRefresh from '../../components/AutoRefresh.tsx'
import PageRangeSelector from '../../components/PageRangeSelector.tsx'
import LatexText from '../../components/LatexText.tsx'

if (!Astro.locals.user) return Astro.redirect('/login')

const userId = Astro.locals.user.id
const docId = Astro.params.id!

// Load document (verify ownership)
const [doc] = await db
  .select()
  .from(documents)
  .where(and(eq(documents.id, docId), eq(documents.userId, userId)))
  .limit(1)

if (!doc) return Astro.redirect('/library')

// Load most recent job for this document
const [job] = await db
  .select()
  .from(jobs)
  .where(and(eq(jobs.documentId, docId), eq(jobs.userId, userId)))
  .orderBy(jobs.createdAt)
  .limit(1)

const isPending = doc.processingStatus === 'pending'
const isPreview = doc.processingStatus === 'preview'
const isChunking = doc.processingStatus === 'chunking'
const isGenerating = doc.processingStatus === 'generating'
const isError = doc.processingStatus === 'error'

// Load cards grouped by chunk (even while still generating — show partial progress)
type CardRow = typeof cards.$inferSelect
type ChunkRow = typeof chunks.$inferSelect
type GroupedCard = { chunk: ChunkRow; cards: CardRow[] }

let grouped: GroupedCard[] = []
let chunksWithCards = 0
let totalTextChunks = 0

if (!isPending && !isPreview && !isChunking && !isError) {
  // Count text chunks for progress display
  const textChunkRows = await db
    .select()
    .from(chunks)
    .where(and(eq(chunks.documentId, docId), eq(chunks.userId, userId)))
  totalTextChunks = textChunkRows.filter((c) => c.chunkType === 'text' || c.chunkType === 'code').length
  const cardRows = await db
    .select()
    .from(cards)
    .innerJoin(chunks, eq(cards.chunkId, chunks.id))
    .where(and(eq(cards.userId, userId), eq(chunks.documentId, docId)))
    .orderBy(chunks.chunkIndex)

  // Group cards by chunk
  const chunkMap = new Map<string, GroupedCard>()
  for (const row of cardRows) {
    const key = row.chunks.id
    if (!chunkMap.has(key)) chunkMap.set(key, { chunk: row.chunks, cards: [] })
    chunkMap.get(key)!.cards.push(row.cards)
  }
  grouped = Array.from(chunkMap.values())
  chunksWithCards = chunkMap.size
}

const CARD_TYPE_LABEL: Record<string, string> = {
  discover: 'Discover',
  raw_commentary: 'Notes',
}
const CARD_TYPE_COLOR: Record<string, string> = {
  discover: 'text-ctp-blue',
  raw_commentary: 'text-ctp-green',
}
---

<Layout title={`${doc.title} — Scroll Reader`}>
  <div class="mx-auto max-w-3xl space-y-8 px-4 py-10">
    <!-- Header -->
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold">{doc.title}</h1>
        {doc.processingStatus === 'ready' && (
          <p class="mt-1 text-sm text-ctp-subtext0">
            {(doc.cardStrategy as CardStrategy | null)?.cardTypes?.length === 0
              ? `${doc.chunkCount} passage${doc.chunkCount !== 1 ? 's' : ''} · reading mode`
              : `${doc.cardCount} card${doc.cardCount !== 1 ? 's' : ''} · ${doc.chunkCount} passage${doc.chunkCount !== 1 ? 's' : ''}`
            }
          </p>
        )}
      </div>
      <button
        data-delete-doc
        data-doc-id={doc.id}
        class="rounded-md p-2 text-ctp-subtext0 transition-colors hover:bg-ctp-red/10 hover:text-ctp-red"
        title="Delete document"
      >
        <Icon name="mdi:delete-outline" class="size-5" />
      </button>
    </div>

    <!-- Pending: extracting page count -->
    {isPending && (
      <JobPoller jobId={job?.id ?? ''} client:load />
    )}

    <!-- Preview: page range selector -->
    {isPreview && doc.totalPages && (
      <PageRangeSelector
        docId={doc.id}
        totalPages={doc.totalPages}
        initialStart={doc.pageStart ?? 1}
        initialEnd={doc.pageEnd ?? doc.totalPages}
        client:load
      />
    )}

    <!-- Chunking state: show spinner -->
    {isChunking && job && (
      <JobPoller jobId={job.id} client:load />
    )}

    <!-- Error state -->
    {isError && (
      <div class="rounded-xl bg-ctp-red/10 px-6 py-4 text-ctp-red">
        <p class="font-medium">Processing failed</p>
        {job?.error && <p class="mt-1 text-sm opacity-80">{job.error}</p>}
        <a href="/upload" class="mt-3 inline-block text-sm font-medium underline">
          Try another document
        </a>
      </div>
    )}

    <!-- Generating state: show drip progress -->
    {isGenerating && (
      <div class="rounded-xl border border-ctp-surface1 bg-ctp-surface0 px-6 py-4 space-y-2">
        <div class="flex items-center gap-3 text-ctp-mauve">
          <Icon name="mdi:clock-outline" class="size-5" />
          <p class="text-sm font-medium">
            Processing gradually — {chunksWithCards} of {totalTextChunks} passages complete
          </p>
        </div>
        <p class="text-xs text-ctp-subtext0">
          New cards are generated daily. Check back tomorrow for more.
        </p>
        {/* Progress bar */}
        {totalTextChunks > 0 && (
          <div class="h-1.5 rounded-full bg-ctp-surface2 overflow-hidden">
            <div
              class="h-full rounded-full bg-ctp-mauve transition-all"
              style={`width: ${Math.round((chunksWithCards / totalTextChunks) * 100)}%`}
            />
          </div>
        )}
      </div>
    )}

    <!-- Cards (shown during generating + when ready) -->
    {!isPending && !isPreview && !isChunking && !isError && grouped.map(({ chunk, cards: chunkCards }) => (
      <section class="space-y-3">
        {chunk.chapter && (
          <h2 class="text-xs font-semibold uppercase tracking-widest text-ctp-subtext0">
            {chunk.chapter}
          </h2>
        )}
        {chunk.chunkType === 'code' ? (
          <div class="relative rounded-lg bg-ctp-mantle overflow-hidden">
            {chunk.language && chunk.language !== 'en' && (
              <span class="absolute right-2 top-2 text-xs text-ctp-subtext0/60 font-mono">
                {chunk.language}
              </span>
            )}
            <pre class="overflow-x-auto px-4 py-3 text-xs leading-relaxed max-h-64"><code class="text-ctp-text font-mono whitespace-pre">{chunk.content}</code></pre>
          </div>
        ) : (
          <div class="rounded-lg bg-ctp-surface0 px-4 py-3 text-sm text-ctp-subtext1 leading-relaxed">
            <LatexText text={chunk.content} class="text-sm leading-relaxed text-ctp-subtext1" client:load />
          </div>
        )}
        <div class="grid gap-3 sm:grid-cols-3">
          {chunkCards.map((card) => (
            <div class="rounded-xl border border-ctp-surface1 bg-ctp-surface0 p-4 space-y-2">
              <span class={`text-xs font-semibold uppercase tracking-wide ${CARD_TYPE_COLOR[card.cardType] ?? 'text-ctp-subtext0'}`}>
                {CARD_TYPE_LABEL[card.cardType] ?? card.cardType}
              </span>
              <LatexText text={card.front} class="text-sm leading-relaxed text-ctp-text" client:load />
            </div>
          ))}
        </div>
      </section>
    ))}

    {!isPending && !isPreview && !isChunking && !isGenerating && !isError && grouped.length === 0 && (
      <div class="rounded-xl border border-ctp-surface1 bg-ctp-surface0 px-6 py-4 text-center space-y-1">
        {(doc.cardStrategy as CardStrategy | null)?.cardTypes?.length === 0 ? (
          <>
            <p class="text-ctp-text font-medium">Reading mode</p>
            <p class="text-sm text-ctp-subtext0">No cards for this document — just reading.</p>
          </>
        ) : (
          <p class="text-ctp-subtext0">No cards generated for this document.</p>
        )}
      </div>
    )}
  </div>
</Layout>

<script>
  document.querySelector('[data-delete-doc]')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLElement
    const docId = btn.dataset.docId
    if (!confirm('Delete this document and all its cards?')) return

    const res = await fetch(`/api/documents/${docId}`, { method: 'DELETE' })
    if (res.ok) {
      window.location.href = '/library'
    } else {
      alert('Failed to delete document.')
    }
  })
</script>
