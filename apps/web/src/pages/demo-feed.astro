---
import 'katex/dist/katex.min.css'
import LandingLayout from '../layouts/LandingLayout.astro'
import LpNav from '../components/LpNav.astro'
import DemoFeedComponent from '../components/DemoFeed.tsx'

export const prerender = true;
---

<LandingLayout title="Demo Feed — Scroll Reader">

  <LpNav />

  <!-- DEMO FEED -->
  <main class="pt-24 min-h-screen">
    <div class="mx-auto max-w-xl px-4 pb-8 text-center">
      <p class="font-body text-[0.7rem] font-semibold uppercase tracking-[0.25em] text-ed-on-surface-muted mb-4">Live Demo</p>
      <h1 class="font-display text-3xl font-normal italic text-ed-on-surface mb-3">See your feed in action</h1>
      <p class="font-body text-sm font-light text-ed-on-surface-dim leading-relaxed">
        Real cards generated from public domain books. Scroll, tap, quiz yourself — everything works.
      </p>
    </div>

    <section class="mx-auto w-full max-w-2xl px-4 py-8">
      <DemoFeedComponent dataUrl="/demo-cards.json" client:load />
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="lp-footer">
    <div class="lp-footer-left">
      <a href="/" class="lp-footer-logo">Scroll Reader</a>
      <span class="lp-footer-tagline">Read deeply. Scroll freely.</span>
    </div>
    <ul class="lp-footer-links">
      <li><a href="/privacy">Privacy</a></li>
      <li><a href="/terms">Terms</a></li>
      <li><span class="lp-footer-copy">&copy; {new Date().getFullYear()}</span></li>
    </ul>
  </footer>

</LandingLayout>
