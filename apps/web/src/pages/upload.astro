---
import Layout from '../layouts/Layout.astro'
import { Icon } from 'astro-icon/components'

if (!Astro.locals.user) return Astro.redirect('/login')

const error = Astro.url.searchParams.get('error')
---

<Layout title="Upload — Scroll Reader" noindex>
  <main class="flex h-[calc(100vh-8rem)] items-center justify-center p-6">
    <div class="w-full max-w-lg space-y-8">
      <div>
        <h1 class="font-display text-3xl font-semibold tracking-tight text-ed-on-surface">
          Upload a document
        </h1>
        <p class="mt-2 font-body text-sm text-ed-on-surface-muted">
          We'll extract and generate reading cards from your document.
        </p>
      </div>

      {error && (
        <p class="rounded bg-red-900/10 px-4 py-2 font-body text-sm text-red-400">{error}</p>
      )}

      <form
        id="upload-form"
        method="POST"
        action="/api/upload"
        enctype="multipart/form-data"
        class="space-y-6"
      >
        <!-- Drop zone -->
        <label
          id="drop-zone"
          class="flex cursor-pointer flex-col items-center gap-3 rounded bg-ed-surface-high px-6 py-12 text-center transition-colors hover:bg-ed-surface-highest"
        >
          <Icon name="mdi:file-upload-outline" class="size-10 text-ed-primary" />
          <div>
            <p class="font-body font-medium text-ed-on-surface">Drop an EPUB or PDF here</p>
            <p class="mt-1 font-body text-sm text-ed-on-surface-muted">or click to browse</p>
          </div>
          <input
            id="file-input"
            name="file"
            type="file"
            accept=".epub,.pdf,.txt"
            required
            class="sr-only"
          />
          <p id="file-name" class="hidden font-body text-sm font-medium text-ed-primary"></p>
        </label>

        <!-- Privacy -->
        <label class="flex cursor-pointer items-start gap-3">
          <input
            type="checkbox"
            name="privacy_acknowledged"
            value="true"
            required
            class="mt-0.5 accent-ed-primary"
          />
          <span class="font-body text-sm text-ed-on-surface-dim">
            I understand this document will be processed by an AI model to generate reading cards. I will only upload content I have the right to use.
          </span>
        </label>

        <button
          type="submit"
          id="submit-btn"
          class="w-full rounded bg-ed-primary cursor-pointer px-4 py-2.5 font-body font-medium text-ed-on-primary transition-opacity hover:opacity-90 disabled:opacity-50"
        >
          Upload &amp; process
        </button>
      </form>

      <div class="text-center space-y-2">
        <p class="font-body text-sm text-ed-on-surface-muted">
          Or <a href="/explore" class="font-medium text-ed-primary hover:underline">browse public domain books</a> from Project Gutenberg
        </p>
        <p class="font-body text-sm text-ed-on-surface-muted">
          <a href="/library" class="font-medium text-ed-primary hover:underline">← Back to library</a>
        </p>
      </div>
    </div>
  </main>
</Layout>

<script>
  const input = document.getElementById('file-input') as HTMLInputElement
  const label = document.getElementById('file-name') as HTMLParagraphElement
  const form = document.getElementById('upload-form') as HTMLFormElement
  const btn = document.getElementById('submit-btn') as HTMLButtonElement

  input?.addEventListener('change', () => {
    const name = input.files?.[0]?.name
    if (name) {
      label.textContent = name
      label.classList.remove('hidden')
    }
  })

  form?.addEventListener('submit', () => {
    btn.disabled = true
    btn.textContent = 'Uploading…'
  })
</script>
