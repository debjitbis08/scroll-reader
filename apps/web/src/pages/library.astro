---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { eq, desc, sql, and, inArray } from "drizzle-orm";
import { db } from "../lib/db.ts";
import { documents, cards, chunks, collections, collectionDocuments } from "@scroll-reader/db";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const docs = await db
  .select()
  .from(documents)
  .where(eq(documents.userId, user.id))
  .orderBy(desc(documents.createdAt));

// Live card counts from DB (document.cardCount may lag behind)
const cardCounts = await db
  .select({
    documentId: chunks.documentId,
    count: sql<number>`count(${cards.id})::int`,
  })
  .from(cards)
  .innerJoin(chunks, eq(cards.chunkId, chunks.id))
  .where(eq(cards.userId, user.id))
  .groupBy(chunks.documentId);

const cardCountMap = new Map(cardCounts.map((r) => [r.documentId, r.count]));

// Collections
const userCollections = await db
  .select({
    id: collections.id,
    name: collections.name,
    documentCount: sql<number>`count(${collectionDocuments.documentId})::int`,
  })
  .from(collections)
  .leftJoin(collectionDocuments, eq(collectionDocuments.collectionId, collections.id))
  .where(eq(collections.userId, user.id))
  .groupBy(collections.id)
  .orderBy(collections.name);

// Document → collection memberships (for badges)
const allMemberships = await db
  .select({
    documentId: collectionDocuments.documentId,
    collectionId: collectionDocuments.collectionId,
    collectionName: collections.name,
  })
  .from(collectionDocuments)
  .innerJoin(collections, and(eq(collections.id, collectionDocuments.collectionId), eq(collections.userId, user.id)));

const docCollectionMap = new Map<string, { id: string; name: string }[]>();
for (const m of allMemberships) {
  const list = docCollectionMap.get(m.documentId) ?? [];
  list.push({ id: m.collectionId, name: m.collectionName });
  docCollectionMap.set(m.documentId, list);
}

// Collection filter from URL
const filterCollectionId = Astro.url.searchParams.get('collection') || null;
const filteredDocs = filterCollectionId
  ? docs.filter((d) => docCollectionMap.get(d.id)?.some((c) => c.id === filterCollectionId))
  : docs;
const activeCollectionName = filterCollectionId
  ? userCollections.find((c) => c.id === filterCollectionId)?.name ?? null
  : null;

const STATUS_LABEL: Record<string, string> = {
  pending: "Pending",
  preview: "Select pages",
  chunking: "Processing",
  generating: "Generating",
  ready: "Ready",
  error: "Error",
};

const DOC_TYPE_ICON: Record<string, string> = {
  book: "mdi:book-open-variant",
  fiction: "mdi:book-open-variant",
  paper: "mdi:file-document-outline",
  article: "mdi:newspaper-variant-outline",
  manual: "mdi:book-education-outline",
  note: "mdi:note-text-outline",
  scripture: "mdi:book-cross",
  other: "mdi:file-document-outline",
};

const READING_GOAL_LABEL: Record<string, string> = {
  casual: "Casual",
  reflective: "Reflective",
  study: "Study",
};
---

<Layout title="Library — Scroll Reader" noindex>
  <main class="min-h-screen">
    <section class="mx-auto max-w-3xl px-4 py-8 md:py-12">
      {
        docs.length === 0 ? (
          <div class="flex flex-col items-center gap-5 py-20 text-center">
            <Icon
              name="mdi:bookshelf"
              class="size-12 text-ed-on-surface-muted"
            />
            <p class="font-display text-xl text-ed-on-surface-dim">
              Your library is empty
            </p>
            <a
              href="/upload"
              class="rounded bg-ed-primary px-5 py-2 font-body text-sm font-medium text-ed-on-primary transition-colors hover:opacity-90"
            >
              Upload your first document
            </a>
          </div>
        ) : (
          <div>
            <h1 class="text-2xl mb-4 font-display">My Library</h1>

            {/* Collection filter chips */}
            {userCollections.length > 0 && (
              <div class="flex flex-wrap items-center gap-1.5 mb-4">
                <a
                  href="/library"
                  class:list={[
                    "rounded-full px-3 py-1 font-body text-xs transition-colors",
                    !filterCollectionId
                      ? "bg-ed-primary text-ed-on-primary"
                      : "bg-ed-surface-high text-ed-on-surface-muted hover:bg-ed-surface-highest",
                  ]}
                >
                  All
                </a>
                {userCollections.map((col) => (
                  <a
                    href={`/library?collection=${col.id}`}
                    class:list={[
                      "rounded-full px-3 py-1 font-body text-xs transition-colors",
                      filterCollectionId === col.id
                        ? "bg-ed-primary text-ed-on-primary"
                        : "bg-ed-surface-high text-ed-on-surface-muted hover:bg-ed-surface-highest",
                    ]}
                  >
                    {col.name}
                    <span class="ml-1 opacity-60">{col.documentCount}</span>
                  </a>
                ))}
              </div>
            )}

            <ul class="space-y-2">
              {filteredDocs.map((doc) => {
                const cardCount = cardCountMap.get(doc.id) ?? 0;
                const statusLabel =
                  STATUS_LABEL[doc.processingStatus ?? "pending"];
                const isProcessing =
                  doc.processingStatus === "chunking" ||
                  doc.processingStatus === "generating";
                const isReady = doc.processingStatus === "ready";
                const isError = doc.processingStatus === "error";
                const isRetrying = isProcessing && (doc.retryCount ?? 0) > 0;
                const progressPct = doc.totalElements
                  ? Math.round(
                      ((doc.elementsProcessed ?? 0) / doc.totalElements) * 100,
                    )
                  : 0;
                return (
                  <li>
                    <a
                      href={`/doc/${doc.id}`}
                      class="group flex items-start gap-2 md:gap-4 rounded bg-ed-surface-high px-3 md:px-5 py-4 transition-colors hover:bg-ed-surface-highest"
                    >
                      <Icon
                        name={
                          DOC_TYPE_ICON[doc.documentType] ??
                          "mdi:file-document-outline"
                        }
                        class="size-5 shrink-0 text-ed-on-surface-muted"
                      />
                      <div class="min-w-0 flex-1">
                        <p class="font-display text-base leading-snug text-ed-on-surface group-hover:text-ed-primary transition-colors truncate">
                          {doc.title}
                        </p>
                        <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-0.5 font-body text-[0.7rem] text-ed-on-surface-muted">
                          {doc.author && <span>{doc.author}</span>}
                          {doc.readingGoal && (
                            <span>{READING_GOAL_LABEL[doc.readingGoal]}</span>
                          )}
                          {cardCount > 0 && (
                            <span>
                              {cardCount} card{cardCount !== 1 ? "s" : ""}
                            </span>
                          )}
                          {doc.priority === "pinned" && (
                            <span class="flex items-center gap-0.5 text-ed-primary">
                              <Icon name="mdi:pin" class="size-3" />
                              Pinned
                            </span>
                          )}
                        </div>
                        {(docCollectionMap.get(doc.id) ?? []).length > 0 && (
                          <div class="mt-1 flex flex-wrap gap-1">
                            {(docCollectionMap.get(doc.id) ?? []).map((col) => (
                              <span class="rounded bg-ed-primary-container px-1.5 py-0 font-body text-[0.6rem] text-ed-on-primary-container">
                                {col.name}
                              </span>
                            ))}
                          </div>
                        )}
                        {isProcessing && progressPct > 0 && (
                          <div class="mt-2 h-0.5 rounded-sm bg-ed-surface-container overflow-hidden">
                            <div
                              class="h-full rounded-sm bg-ed-primary transition-all"
                              style={`width: ${progressPct}%`}
                            />
                          </div>
                        )}
                      </div>
                      <span
                        class:list={[
                          "shrink-0 font-body text-[0.65rem] uppercase tracking-[0.15em]",
                          isError
                            ? "text-ed-on-surface-dim"
                            : isReady
                              ? "text-ed-primary"
                              : isProcessing
                                ? "text-ed-on-surface-muted"
                                : "text-ed-on-surface-muted",
                        ]}
                      >
                        {doc.paused ? "Paused" : isRetrying ? "Retrying" : statusLabel}
                      </span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )
      }
    </section>
  </main>
</Layout>
