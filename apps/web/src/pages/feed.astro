---
import Layout from '../layouts/Layout.astro'
import AppNav from '../components/AppNav.astro'
import Feed from '../components/Feed.tsx'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const initialCollection = Astro.url.searchParams.get('collection') || undefined
---

<Layout title="Scroll Reader">
  <main class="min-h-screen bg-ed-surface">
    <div class="flex">
      <AppNav active="feed" />
      <section class="mx-auto w-full max-w-2xl px-4 py-8">
        <Feed initialCollection={initialCollection} client:load />
      </section>
    </div>
  </main>
</Layout>
