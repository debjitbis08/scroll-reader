---
import Layout from '../layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import Feed from '../components/Feed.tsx'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')
---

<Layout title="Feed — Scroll Reader">
  <main class="min-h-screen">
    <header class="flex items-center justify-between border-b border-ctp-surface0 px-4 py-3">
      <div class="flex items-center gap-4">
        <h1 class="text-lg font-semibold tracking-tight">Feed</h1>
        <nav class="flex gap-2 text-sm">
          <a href="/" class="text-ctp-subtext0 hover:text-ctp-text">Library</a>
        </nav>
      </div>
      <div class="flex items-center gap-2">
        <a
          href="/upload"
          class="flex items-center gap-1.5 rounded-lg bg-ctp-mauve px-3 py-1.5 text-sm font-medium text-ctp-base transition-colors hover:bg-ctp-mauve/80"
        >
          <Icon name="mdi:plus" class="size-4" />
          Upload
        </a>
        <button
          data-theme-toggle
          class="rounded-md p-2 text-ctp-subtext0 transition-colors hover:bg-ctp-surface0 hover:text-ctp-text"
        >
          <Icon name="mdi:theme-light-dark" class="size-5" />
        </button>
      </div>
    </header>

    <section class="mx-auto max-w-2xl px-4 py-8">
      <Feed client:load />
    </section>
  </main>
</Layout>
