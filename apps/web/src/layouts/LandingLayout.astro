---
interface Props {
  title?: string
}

const { title = 'Scroll Reader — Read Deeply. Scroll Freely.' } = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,600;1,6..72,300;1,6..72,400;1,6..72,600&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ─── EDITORIAL TOKENS ─── */
  :root {
    --ed-primary: #4d6328;
    --ed-primary-container: #657c3e;
    --ed-on-primary: #ffffff;
    --ed-surface: #fbfbe2;
    --ed-surface-dim: #f5f5dc;
    --ed-surface-container: #ededce;
    --ed-surface-high: #e4e4cc;
    --ed-surface-highest: #d8d8c0;
    --ed-on-surface: #1b1d0e;
    --ed-on-surface-dim: #4a4a3a;
    --ed-on-surface-muted: #8a8870;
    --ed-outline: #c5c3b0;
    --ed-outline-dim: #c5c3b022;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --ed-primary: #c8c8b0;
      --ed-primary-container: #474836;
      --ed-on-primary: #404130;
      --ed-surface: #0e0e0e;
      --ed-surface-dim: #141412;
      --ed-surface-container: #1c1c1a;
      --ed-surface-high: #252523;
      --ed-surface-highest: #333330;
      --ed-on-surface: #e7e5e5;
      --ed-on-surface-dim: #a8a6a0;
      --ed-on-surface-muted: #6b6860;
      --ed-outline: #49473f;
      --ed-outline-dim: #49473f22;
    }
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--ed-surface);
    color: var(--ed-on-surface);
    font-family: 'Inter', system-ui, sans-serif;
    overflow-x: hidden;
    line-height: 1.6;
    font-weight: 400;
  }

  /* ─── NAV ─── */
  .lp-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: color-mix(in srgb, var(--ed-surface) 85%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .lp-logo {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 400;
    color: var(--ed-on-surface);
    text-decoration: none;
  }

  .lp-nav-links {
    list-style: none;
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .lp-nav-links a {
    font-size: 0.8rem;
    color: var(--ed-on-surface-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .lp-nav-links a:hover { color: var(--ed-on-surface); }

  .lp-nav-cta {
    font-size: 0.75rem !important;
    font-weight: 500 !important;
    letter-spacing: 0.04em;
    color: var(--ed-on-primary) !important;
    background: var(--ed-primary);
    padding: 0.5rem 1.25rem;
    border-radius: 0.25rem;
    transition: opacity 0.2s;
  }

  .lp-nav-cta:hover { opacity: 0.85; color: var(--ed-on-primary) !important; }

  /* ─── HERO ─── */
  .lp-hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 8rem 3rem 4rem;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .lp-hero-text {
    animation: lpFadeUp 0.8s ease both;
  }

  .lp-hero h1 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.8rem, 5.5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--ed-on-surface);
  }

  .lp-hero h1 em {
    font-style: italic;
    color: var(--ed-primary);
  }

  .lp-hero-sub {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--ed-on-surface-dim);
    max-width: 44ch;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .lp-cta-row {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .lp-btn-primary {
    background: var(--ed-primary);
    color: var(--ed-on-primary);
    border: none;
    padding: 0.8rem 2rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: 0.25rem;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.15s;
  }

  .lp-btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .lp-btn-ghost {
    color: var(--ed-on-surface-dim);
    border: 1px solid var(--ed-outline);
    background: transparent;
    padding: 0.8rem 2rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: 0.25rem;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .lp-btn-ghost:hover {
    border-color: var(--ed-primary);
    color: var(--ed-primary);
  }

  /* Hero visual placeholder — for future screenshot/video */
  .lp-hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    animation: lpFadeUp 0.8s 0.15s ease both;
  }

  .lp-hero-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--ed-surface-high);
    border-radius: 0.375rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ed-on-surface-muted);
    font-size: 0.8rem;
    font-style: italic;
  }

  /* ─── MANIFESTO ─── */
  .lp-manifesto {
    padding: 7rem 3rem;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .lp-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ed-on-surface-muted);
    margin-bottom: 1.5rem;
  }

  .lp-manifesto h2 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 2rem;
    color: var(--ed-on-surface);
  }

  .lp-manifesto h2 em {
    font-style: italic;
    color: var(--ed-primary);
  }

  .lp-manifesto-body {
    font-size: 1rem;
    font-weight: 300;
    color: var(--ed-on-surface-dim);
    max-width: 60ch;
    margin: 0 auto 3.5rem;
    line-height: 1.8;
  }

  .lp-manifesto-body strong {
    font-weight: 600;
    color: var(--ed-on-surface);
  }

  /* Principle cards */
  .lp-principles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
    text-align: left;
  }

  .lp-principle {
    padding: 0.5rem 0;
  }

  .lp-principle-icon {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--ed-primary);
  }

  .lp-principle h4 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 400;
    font-style: italic;
    margin-bottom: 0.5rem;
    color: var(--ed-on-surface);
  }

  .lp-principle p {
    font-size: 0.85rem;
    color: var(--ed-on-surface-muted);
    line-height: 1.65;
    font-weight: 300;
  }

  /* ─── HOW IT WORKS ─── */
  .lp-how {
    padding: 6rem 3rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .lp-how h2 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 400;
    text-align: center;
    margin-bottom: 3.5rem;
    color: var(--ed-on-surface);
  }

  .lp-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  .lp-step-icon {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--ed-surface-high);
    border-radius: 0.375rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    font-size: 1rem;
    color: var(--ed-primary);
  }

  .lp-step h3 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    color: var(--ed-on-surface);
  }

  .lp-step p {
    font-size: 0.85rem;
    color: var(--ed-on-surface-muted);
    font-weight: 300;
    line-height: 1.7;
  }

  /* ─── CARD TYPES ─── */
  .lp-cards {
    padding: 6rem 3rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .lp-cards-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2.5rem;
    gap: 2rem;
  }

  .lp-cards-header h2 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 400;
    color: var(--ed-on-surface);
  }

  .lp-cards-header .lp-eyebrow {
    margin-bottom: 0;
    white-space: nowrap;
  }

  .lp-card-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .lp-card-type {
    background: var(--ed-surface-high);
    padding: 1.5rem 1.25rem;
    border-radius: 0.25rem;
    transition: transform 0.2s;
  }

  .lp-card-type:hover { transform: translateY(-3px); }

  .lp-card-type-icon {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--ed-primary);
  }

  .lp-card-type h4 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    color: var(--ed-on-surface);
  }

  .lp-card-type p {
    font-size: 0.8rem;
    color: var(--ed-on-surface-muted);
    line-height: 1.55;
    font-weight: 300;
  }

  /* ─── DEPLOY ─── */
  .lp-deploy {
    padding: 6rem 3rem;
    text-align: center;
    max-width: 1000px;
    margin: 0 auto;
  }

  .lp-deploy h2 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 400;
    font-style: italic;
    margin-bottom: 0.75rem;
    color: var(--ed-on-surface);
  }

  .lp-deploy > .lp-eyebrow { margin-bottom: 3rem; }

  .lp-deploy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    text-align: left;
  }

  .lp-deploy-card {
    background: var(--ed-surface-high);
    padding: 1.75rem;
    border-radius: 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .lp-deploy-tag {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 2px;
    display: inline-block;
    width: fit-content;
  }

  .lp-tag-current {
    background: var(--ed-primary);
    color: var(--ed-on-primary);
  }

  .lp-tag-soon {
    background: var(--ed-outline-dim);
    color: var(--ed-on-surface-muted);
    border: 1px solid var(--ed-outline);
  }

  .lp-deploy-card h4 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--ed-on-surface);
  }

  .lp-deploy-card p {
    font-size: 0.85rem;
    color: var(--ed-on-surface-muted);
    line-height: 1.6;
    font-weight: 300;
    flex: 1;
  }

  .lp-deploy-card .lp-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-top: 0.25rem;
  }

  .lp-deploy-card .lp-features li {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ed-on-surface-dim);
  }

  .lp-deploy-card .lp-features li::before {
    content: '\2713';
    margin-right: 0.5rem;
    color: var(--ed-primary);
  }

  .lp-deploy-btn {
    display: block;
    text-align: center;
    padding: 0.7rem;
    border: 1px solid var(--ed-outline);
    border-radius: 0.25rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--ed-on-surface-dim);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    margin-top: 0.5rem;
  }

  .lp-deploy-btn:hover {
    border-color: var(--ed-primary);
    color: var(--ed-primary);
  }

  .lp-deploy-btn-primary {
    background: var(--ed-primary);
    color: var(--ed-on-primary);
    border-color: var(--ed-primary);
  }

  .lp-deploy-btn-primary:hover {
    opacity: 0.85;
    color: var(--ed-on-primary);
  }

  /* ─── FINAL CTA ─── */
  .lp-cta {
    padding: 8rem 3rem;
    text-align: center;
  }

  .lp-cta h2 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.15;
    margin-bottom: 1rem;
    color: var(--ed-on-surface);
  }

  .lp-cta p {
    font-size: 1rem;
    color: var(--ed-on-surface-muted);
    font-weight: 300;
    margin-bottom: 2rem;
  }

  .lp-cta-small {
    font-size: 0.7rem !important;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 1rem !important;
    margin-bottom: 0 !important;
  }

  /* ─── FOOTER ─── */
  .lp-footer {
    padding: 2.5rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .lp-footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .lp-footer-logo {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--ed-on-surface);
    text-decoration: none;
  }

  .lp-footer-tagline {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 0.8rem;
    font-style: italic;
    color: var(--ed-on-surface-muted);
  }

  .lp-footer-links {
    list-style: none;
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .lp-footer-links a {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ed-on-surface-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .lp-footer-links a:hover { color: var(--ed-primary); }

  .lp-footer-copy {
    font-size: 0.65rem;
    color: var(--ed-on-surface-muted);
    letter-spacing: 0.05em;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes lpFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lp-fade {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .lp-fade.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .lp-nav { padding: 1rem 1.5rem; }
    .lp-nav-links { display: none; }
    .lp-hero { grid-template-columns: 1fr; padding: 7rem 1.5rem 3rem; gap: 2rem; }
    .lp-hero-visual { display: none; }
    .lp-principles { grid-template-columns: 1fr; }
    .lp-steps { grid-template-columns: 1fr; }
    .lp-card-grid { grid-template-columns: repeat(2, 1fr); }
    .lp-cards-header { flex-direction: column; gap: 0.5rem; }
    .lp-deploy-grid { grid-template-columns: 1fr; }
    .lp-manifesto, .lp-how, .lp-cards, .lp-deploy, .lp-cta { padding: 4rem 1.5rem; }
    .lp-footer { flex-direction: column; gap: 1.5rem; text-align: center; }
    .lp-footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>
