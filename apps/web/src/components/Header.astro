---
import { Icon } from 'astro-icon/components'

const user = Astro.locals.user
---

<header class="sticky top-0 z-50 bg-ed-surface/80 backdrop-blur-lg">
  <div class="flex items-center justify-between px-4 py-3">
    <a href="/feed" class="flex items-center gap-2">
      <Icon name="fa6-solid:scroll" class="size-5 text-ed-primary" />
      <span class="font-display text-lg tracking-tight text-ed-on-surface">Scroll Reader</span>
    </a>
    <div class="flex items-center gap-2">
      {user && (
        <>
          <a href="/library" class="font-body text-sm text-ed-on-surface-muted hover:text-ed-on-surface transition-colors">Library</a>
          <a
            href="/upload"
            class="flex items-center gap-1.5 rounded bg-ed-primary px-3 py-1.5 font-body text-sm font-medium text-ed-on-primary transition-colors hover:bg-ed-primary/80"
          >
            <Icon name="mdi:plus" class="size-4" />
            Upload
          </a>
          <form method="POST" action="/api/auth/logout">
            <button
              type="submit"
              class="rounded p-2 text-ed-on-surface-muted transition-colors hover:text-ed-on-surface"
              title="Log out"
            >
              <Icon name="mdi:logout" class="size-5" />
            </button>
          </form>
        </>
      )}
      <button
        data-theme-toggle
        class="rounded p-2 text-ed-on-surface-muted transition-colors hover:text-ed-on-surface"
      >
        <Icon name="fa6-solid:sun" class="size-5 theme-icon hidden" data-theme-icon="latte" />
        <Icon name="fa6-solid:moon" class="size-5 theme-icon hidden" data-theme-icon="mocha" />
        <Icon name="fa6-solid:desktop" class="size-5 theme-icon" data-theme-icon="auto" />
      </button>
    </div>
  </div>
</header>
