---
import Layout from '../layouts/Layout.astro'

if (Astro.locals.user) return Astro.redirect('/')

const error = Astro.url.searchParams.get('error')
const errorMsg: Record<string, string> = {
  missing_fields: 'Email and password are required.',
  privacy_required: 'You must acknowledge the privacy notice to continue.',
  signup_failed: 'Sign-up failed. Please try again.',
}
---

<Layout title="Create account — Scroll Reader">
  <main class="flex min-h-screen items-center justify-center">
    <div class="w-full max-w-sm space-y-6 p-6">
      <h1 class="text-2xl font-bold">Create account</h1>

      {error && (
        <p class="rounded-lg bg-ctp-red/10 px-4 py-2 text-sm text-ctp-red">
          {errorMsg[error] ?? error}
        </p>
      )}

      <form method="POST" action="/api/auth/register" class="space-y-4">
        <div class="space-y-1">
          <label for="display_name" class="block text-sm font-medium text-ctp-subtext0">
            Display name <span class="text-ctp-overlay0">(optional)</span>
          </label>
          <input
            id="display_name"
            name="display_name"
            type="text"
            autocomplete="name"
            class="w-full rounded-lg border border-ctp-surface1 bg-ctp-surface0 px-3 py-2 text-ctp-text placeholder-ctp-overlay0 focus:border-ctp-mauve focus:outline-none"
          />
        </div>
        <div class="space-y-1">
          <label for="email" class="block text-sm font-medium text-ctp-subtext0">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-ctp-surface1 bg-ctp-surface0 px-3 py-2 text-ctp-text placeholder-ctp-overlay0 focus:border-ctp-mauve focus:outline-none"
          />
        </div>
        <div class="space-y-1">
          <label for="password" class="block text-sm font-medium text-ctp-subtext0">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            required
            autocomplete="new-password"
            minlength="8"
            class="w-full rounded-lg border border-ctp-surface1 bg-ctp-surface0 px-3 py-2 text-ctp-text placeholder-ctp-overlay0 focus:border-ctp-mauve focus:outline-none"
          />
        </div>

        <label class="flex items-start gap-3 cursor-pointer">
          <input
            type="checkbox"
            name="privacy_acknowledged"
            value="true"
            required
            class="mt-0.5 accent-ctp-mauve"
          />
          <span class="text-sm text-ctp-subtext1">
            I understand that documents I upload will be processed by an AI model to generate reading
            cards. I will only upload content I have the right to share.
          </span>
        </label>

        <button
          type="submit"
          class="w-full rounded-lg bg-ctp-mauve px-4 py-2 font-medium text-ctp-base transition-opacity hover:opacity-90"
        >
          Create account
        </button>
      </form>

      <p class="text-center text-sm text-ctp-subtext0">
        Already have an account?
        <a href="/login" class="font-medium text-ctp-mauve hover:underline">Sign in</a>
      </p>
    </div>
  </main>
</Layout>
