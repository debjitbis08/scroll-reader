---
import Layout from '../layouts/Layout.astro'
import AppNav from '../components/AppNav.astro'
import FeedComp from '../components/Feed.tsx'
import { eq, and, sql, gte } from 'drizzle-orm'
import { db } from '../lib/db.ts'
import { profiles, usageEvents, feedEvents } from '@scroll-reader/db'
import type { Tier } from '@scroll-reader/shared-types'
import { TIER_LIMITS } from '@scroll-reader/shared-types'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const [profileRow] = await db
  .select({ tier: profiles.tier })
  .from(profiles)
  .where(eq(profiles.id, user.id))
  .limit(1)

const userTier = (profileRow?.tier ?? 'free') as Tier
const dailyLimit = TIER_LIMITS[userTier].cardsPerDay

const todayStart = new Date()
todayStart.setUTCHours(0, 0, 0, 0)
const [quotaRow] = await db
  .select({ total: sql<number>`coalesce(sum(${usageEvents.quantity}), 0)::int` })
  .from(usageEvents)
  .where(and(
    eq(usageEvents.userId, user.id),
    eq(usageEvents.eventType, 'cards_generated'),
    gte(usageEvents.occurredAt, todayStart),
  ))
const cardsToday = quotaRow?.total ?? 0
const quotaExhausted = cardsToday >= dailyLimit

const resetAt = new Date()
resetAt.setUTCHours(24, 0, 0, 0)

// Show onboarding guide if user has never scrolled the feed
const [impressionRow] = await db
  .select({ count: sql<number>`count(*)::int` })
  .from(feedEvents)
  .where(eq(feedEvents.userId, user.id))
const isNewUser = (impressionRow?.count ?? 0) === 0

const initialCollection = Astro.url.searchParams.get('collection') || undefined
---

<Layout title="Scroll Reader" noindex>
  <main class="min-h-screen bg-ed-surface">
    <div class="flex">
      <AppNav active="feed" />
      <section class="mx-auto w-full max-w-2xl px-4 py-8 space-y-4">
        <div class="flex items-center justify-between gap-3 rounded bg-ed-surface-high px-4 py-2.5">
          <p class="font-body text-[0.7rem] text-ed-on-surface-muted">
            {quotaExhausted
              ? <>Daily card limit reached. New cards eligible <time id="feed-quota-reset" datetime={resetAt.toISOString()} class="text-ed-on-surface">{resetAt.toUTCString()}</time>.</>
              : <>{cardsToday} of {dailyLimit} cards generated today · resets <time id="feed-quota-reset" datetime={resetAt.toISOString()} class="text-ed-on-surface">{resetAt.toUTCString()}</time></>}
          </p>
          <div class="flex items-center gap-2 shrink-0">
            <span class="font-display text-xs tabular-nums text-ed-on-surface">{cardsToday}<span class="text-ed-on-surface-muted">/{dailyLimit}</span></span>
            <div class="w-16 h-1 rounded-full bg-ed-outline-dim overflow-hidden">
              <div
                class:list={['h-full rounded-full', quotaExhausted ? 'bg-ed-error' : 'bg-ed-primary']}
                style={`width: ${Math.min(100, Math.round((cardsToday / dailyLimit) * 100))}%`}
              />
            </div>
          </div>
        </div>
        {isNewUser && (
          <div id="feed-onboarding" class="rounded bg-ed-surface-high p-5 space-y-4">
            <div class="flex items-start justify-between gap-3">
              <h2 class="font-display text-base text-ed-on-surface">How your feed works</h2>
              <button
                id="dismiss-onboarding"
                class="shrink-0 text-ed-on-surface-muted hover:text-ed-on-surface transition-colors"
                aria-label="Dismiss"
              >
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
              </button>
            </div>
            <p class="font-body text-sm text-ed-on-surface-muted">
              When you upload a document, we break it into sections and generate <strong class="text-ed-on-surface-dim">cards</strong> from each one.
              The type of cards depends on what you chose during setup — your content type and reading goal.
            </p>
            <div class="grid grid-cols-2 gap-x-4 gap-y-2 font-body text-[0.75rem]">
              <div>
                <span class="font-semibold text-ed-on-surface-dim">Discovery</span>
                <span class="text-ed-on-surface-muted"> — key ideas and summaries from the text</span>
              </div>
              <div>
                <span class="font-semibold text-ed-on-surface-dim">Notes</span>
                <span class="text-ed-on-surface-muted"> — commentary and analysis on a passage</span>
              </div>
              <div>
                <span class="font-semibold text-ed-on-surface-dim">Active Recall</span>
                <span class="text-ed-on-surface-muted"> — flip cards to test your memory</span>
              </div>
              <div>
                <span class="font-semibold text-ed-on-surface-dim">Quiz</span>
                <span class="text-ed-on-surface-muted"> — multiple choice questions from the material</span>
              </div>
              <div>
                <span class="font-semibold text-ed-on-surface-dim">Glossary</span>
                <span class="text-ed-on-surface-muted"> — definitions of key terms</span>
              </div>
              <div>
                <span class="font-semibold text-ed-on-surface-dim">Passage</span>
                <span class="text-ed-on-surface-muted"> — notable excerpts worth revisiting</span>
              </div>
              <div>
                <span class="font-semibold text-ed-on-surface-dim">Contrast</span>
                <span class="text-ed-on-surface-muted"> — side-by-side comparison of related ideas</span>
              </div>
            </div>
            <p class="font-body text-xs text-ed-on-surface-dim">
              Just scroll. Cards you interact with are spaced out and resurface over time to help you retain what you've read.
            </p>
          </div>
        )}
        <FeedComp initialCollection={initialCollection} client:load />
      </section>
    </div>
  </main>
</Layout>

<script>
  const dismissBtn = document.getElementById('dismiss-onboarding')
  if (dismissBtn) {
    dismissBtn.addEventListener('click', () => {
      document.getElementById('feed-onboarding')?.remove()
    })
  }

  const el = document.getElementById('feed-quota-reset')
  if (el) {
    const dt = new Date(el.getAttribute('datetime')!)
    const now = new Date()
    const isToday = dt.toDateString() === now.toDateString()
    const time = dt.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' })
    el.textContent = isToday ? `today at ${time}` : `tomorrow at ${time}`
  }
</script>
