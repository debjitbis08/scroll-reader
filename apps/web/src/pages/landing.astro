---
import { Image } from 'astro:assets'
import LandingLayout from '../layouts/LandingLayout.astro'
import FeedDarkImg from '../assets/images/feed-dark.png';
import FeedLightImg from '../assets/images/feed-light.png';
import { Icon } from 'astro-icon/components';
---

<LandingLayout>

  <!-- NAV -->
  <nav class="lp-nav">
    <a href="/" class="lp-logo">Scroll Reader</a>
    <button class="lp-theme-toggle lp-theme-toggle-mobile" data-theme-toggle aria-label="Toggle theme">
      <Icon name="fa6-solid:sun" class="lp-theme-icon" data-theme-icon="latte" />
      <Icon name="fa6-solid:moon" class="lp-theme-icon" data-theme-icon="mocha" />
      <Icon name="fa6-solid:desktop" class="lp-theme-icon" data-theme-icon="auto" />
    </button>
    <ul class="lp-nav-links">
      <li><a href="#why">Why Scroll?</a></li>
      <li><a href="#how">How it works</a></li>
      <li><a href="#cards">Cards</a></li>
      <li><a href="/demo-feed">Demo</a></li>
      <li>
        <button class="lp-theme-toggle" data-theme-toggle aria-label="Toggle theme">
          <Icon name="fa6-solid:sun" class="lp-theme-icon" data-theme-icon="latte" />
          <Icon name="fa6-solid:moon" class="lp-theme-icon" data-theme-icon="mocha" />
          <Icon name="fa6-solid:desktop" class="lp-theme-icon" data-theme-icon="auto" />
        </button>
      </li>
      <li><a href="/login">Sign In</a></li>
      <li><a href="/register" class="lp-nav-cta">Start Reading</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="lp-hero">
    <div class="lp-hero-text">
      <h1>Scroll your<br><em>books,</em> not<br>the timeline.</h1>
      <p class="lp-hero-sub">
        You're going to scroll anyway. Might as well scroll your books.
      </p>
      <div class="lp-cta-row">
        <a href="/register" class="lp-btn-primary">Start Reading</a>
        <a href="/demo-feed" class="lp-btn-ghost">Try the demo</a>
      </div>
    </div>
    <div class="lp-hero-visual">
      <!-- Placeholder for future screenshot/video of the feed -->
      <div class="lp-hero-placeholder">
        <Image src={FeedDarkImg} alt="Screenshot of the feed" class="lp-hero-img lp-hero-img-dark" loading="eager" />
        <Image src={FeedLightImg} alt="Screenshot of the feed" class="lp-hero-img lp-hero-img-light" loading="eager" />
      </div>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="lp-manifesto lp-fade" id="why">
    <p class="lp-eyebrow">The Manifesto</p>
    <h2>Designed for <em>depth,</em><br>not engagement.</h2>
    <p class="lp-manifesto-body">
      Social feeds are designed to keep you scrolling.
      Scroll Reader turns that same habit toward your own library instead.
    </p>
    <p class="lp-manifesto-body">
      No ads. No algorithmic recommendations. No content you didn't choose.
    </p>
  </section>

  <!-- HOW IT WORKS -->
  <section class="lp-how lp-fade" id="how">
    <h2>How it works</h2>
    <div class="lp-steps">
      <div class="lp-step">
        <div class="lp-step-heading">
          <div class="lp-step-icon">
            <Icon name="mdi:file-upload-outline" />
          </div>
          <h3>1. Upload your documents</h3>
        </div>
        <p>
Drop in an EPUB or PDF. We pull out the text, divide it into sections, and pick up images along the way.
        </p>
      </div>
      <div class="lp-step">
        <div class="lp-step-heading">
          <div class="lp-step-icon">
            <Icon name="mdi:sparkles-outline" />
          </div>
          <h3>2. AI builds your feed</h3>
        </div>
        <p>We send passages to Google's Gemini model, which generates cards — a quiz question, a pulled quote, a concept comparison, a glossary term.
      </div>
      <div class="lp-step">
        <div class="lp-step-heading">
          <div class="lp-step-icon">
            <Icon name="mdi:scroll-text-outline" />
          </div>
          <h3>3. Scroll through your library</h3>
        </div>
        <p>
          Cards appear in a vertical feed. Read one, skip one, save one. How you scroll shapes what comes back and when.
        </p>
      </div>
    </div>
  </section>

  <!-- CARD TYPES -->
  <section class="lp-cards lp-fade" id="cards">
    <div class="lp-cards-header">
      <h2>What a card can be</h2>
    </div>
    <div class="lp-card-grid">
      <div class="lp-card-type">
        <div class="lp-card-type-heading">
        <div class="lp-card-type-icon">
          <Icon name="mdi:telescope" />
        </div>
        <h4>Discover</h4>
        </div>
        <p>The core idea of the passage, distilled. What it says and why it's worth knowing.</p>
      </div>
      <div class="lp-card-type">
        <div class="lp-card-type-heading">
        <div class="lp-card-type-icon">
          <Icon name="mdi:pencil-outline" />
        </div>
        <h4>Notes</h4>
        </div>
        <p>
          A marginal note: a tension surfaced, an assumption questioned, a connection made. Opinionated.
        </p>
      </div>
      <div class="lp-card-type">
        <div class="lp-card-type-heading">
        <div class="lp-card-type-icon">
          <Icon name="mdi:format-quote-open" />
        </div>
        <h4>Passage</h4>
        </div>
        <p>The exact words from your text. Surfaced when the excerpt is worth sitting with on its own.</p>
      </div>
      <div class="lp-card-type">
        <div class="lp-card-type-heading">
        <div class="lp-card-type-icon">
          <Icon name="mdi:help-circle-outline" />
        </div>
        <h4>Quiz</h4>
        </div>
        <p>A multiple-choice question on a concept from the passage. Four options, one right answer, explanations for each.</p>
      </div>
      <div class="lp-card-type">
        <div class="lp-card-type-heading">
        <div class="lp-card-type-icon">
          <Icon name="mdi:card-text-outline" />
        </div>
        <h4>Active Recall</h4>
        </div>
        <p>A question with a hidden answer. Tests whether you've actually absorbed the idea.</p>
      </div>
      <div class="lp-card-type">
        <div class="lp-card-type-heading">
          <div class="lp-card-type-icon">
            <Icon name="mdi:scale-balance" />
          </div>
          <h4>Contrast</h4>
        </div>
        <p>Two ideas from the passage set against each other. What's the difference, and why does it matter.</p>
      </div>
      <div class="lp-card-type">
        <div class="lp-card-type-heading">
        <div class="lp-card-type-icon">
          <Icon name="mdi:book-open-page-variant-outline" />
        </div>
        <h4>Glossary</h4>
        </div>
        <p>A term from the text, defined as the author uses it. Etymology where it's interesting.</p>
      </div>
    </div>
    <p class="lp-card-grid-note">More card types are in progress.</p>
  </section>

  <!-- DEPLOY -->
  <section class="lp-deploy lp-fade" id="deploy">
    <h2>Get started</h2>
    <div class="lp-deploy-grid">
      <div class="lp-deploy-card">
        <span class="lp-deploy-tag lp-tag-current">Available now</span>
        <h4>Web Hosted</h4>
        <p>Upload and start reading. No setup. Runs on our servers. Free to start.</p>
        <a href="/register" class="lp-deploy-btn lp-deploy-btn-primary">Start Reading</a>
      </div>
    </div>
    <p class="lp-deploy-future">
      <strong>Coming later:</strong> A self-hosted Docker version for people who
      want their data on their own machine, and a desktop app with offline support.
    </p>
    <p class="lp-deploy-future" style="display: none;">
      If either of those matters to you, <a href="#">leave your email</a> and
      we'll let you know when they're ready.
    </p>
  </section>

  <!-- FINAL CTA -->
  <section class="lp-cta lp-fade">
    <h2>Your library is already full.</h2>
    <p>This just makes it scrollable.</p>
    <a href="/register" class="lp-btn-primary">Upload your first book &rarr;</a>
  </section>

  <!-- FOOTER -->
  <footer class="lp-footer">
    <div class="lp-footer-left">
      <a href="/" class="lp-footer-logo">Scroll Reader</a>
      <span class="lp-footer-tagline">Put down the feed. Pick up your library.</span>
    </div>
    <ul class="lp-footer-links">
      <li><a href="https://github.com/debjitbis08/scroll-reader" target="_blank">GitHub</a></li>
      <li><a href="/privacy">Privacy</a></li>
      <li><a href="/terms">Terms</a></li>
    </ul>
    <span class="lp-footer-copy">&copy; 2026 Scroll Reader. Licensed under AGPL-3.0.</span>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.lp-fade').forEach(el => observer.observe(el));

    // Theme cycling: auto → latte (light) → mocha (dark) → auto
    const THEMES = ['auto', 'latte', 'mocha'] as const;
    type Theme = (typeof THEMES)[number];

    function getTheme(): Theme {
      return (localStorage.getItem('ctp-theme') as Theme) ?? 'auto';
    }

    function applyTheme(theme: Theme): void {
      const html = document.documentElement;
      html.classList.remove('latte', 'mocha');
      if (theme !== 'auto') html.classList.add(theme);
      localStorage.setItem('ctp-theme', theme);
      html.dataset.theme =
        theme === 'latte' ? 'light' : theme === 'mocha' ? 'dark' : 'auto';
      updateIcons(theme);
    }

    function updateIcons(theme: Theme): void {
      document.querySelectorAll<HTMLElement>('[data-theme-icon]').forEach((icon) => {
        if (icon.dataset.themeIcon === theme) {
          icon.setAttribute('data-active', '');
        } else {
          icon.removeAttribute('data-active');
        }
      });
    }

    document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = THEMES.indexOf(getTheme());
        applyTheme(THEMES[(idx + 1) % THEMES.length]);
      });
    });

    updateIcons(getTheme());
  </script>

</LandingLayout>
