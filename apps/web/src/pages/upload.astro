---
import Layout from '../layouts/Layout.astro'
import { Icon } from 'astro-icon/components'

if (!Astro.locals.user) return Astro.redirect('/login')

const error = Astro.url.searchParams.get('error')
---

<Layout title="Upload — Scroll Reader">
  <main class="flex min-h-screen items-center justify-center p-6">
    <div class="w-full max-w-lg space-y-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold">Upload a document</h1>
          <p class="mt-1 text-sm text-ctp-subtext0">
            We'll generate reading cards from the first few chapters.
          </p>
        </div>
        <button
          data-theme-toggle
          class="rounded-md p-2 text-ctp-subtext0 transition-colors hover:bg-ctp-surface0 hover:text-ctp-text"
        >
          <Icon name="mdi:theme-light-dark" class="size-5" />
        </button>
      </div>

      {error && (
        <p class="rounded-lg bg-ctp-red/10 px-4 py-2 text-sm text-ctp-red">{error}</p>
      )}

      <form
        id="upload-form"
        method="POST"
        action="/api/upload"
        enctype="multipart/form-data"
        class="space-y-5"
      >
        <!-- Drop zone -->
        <label
          id="drop-zone"
          class="flex cursor-pointer flex-col items-center gap-3 rounded-xl border-2 border-dashed border-ctp-surface1 bg-ctp-surface0/50 px-6 py-10 text-center transition-colors hover:border-ctp-mauve hover:bg-ctp-surface0"
        >
          <Icon name="mdi:file-upload-outline" class="size-10 text-ctp-mauve" />
          <div>
            <p class="font-medium text-ctp-text">Drop an EPUB or PDF here</p>
            <p class="mt-1 text-sm text-ctp-subtext0">or click to browse</p>
          </div>
          <input
            id="file-input"
            name="file"
            type="file"
            accept=".epub,.pdf,.txt"
            required
            class="sr-only"
          />
          <p id="file-name" class="text-sm font-medium text-ctp-mauve hidden"></p>
        </label>

        <!-- Privacy -->
        <label class="flex items-start gap-3 cursor-pointer">
          <input
            type="checkbox"
            name="privacy_acknowledged"
            value="true"
            required
            class="mt-0.5 accent-ctp-mauve"
          />
          <span class="text-sm text-ctp-subtext1">
            I understand this document will be processed by an AI model to generate reading cards.
            I will only upload content I have the right to share.
          </span>
        </label>

        <button
          type="submit"
          id="submit-btn"
          class="w-full rounded-lg bg-ctp-mauve px-4 py-2.5 font-medium text-ctp-base transition-opacity hover:opacity-90 disabled:opacity-50"
        >
          Upload &amp; process
        </button>
      </form>

      <p class="text-center text-sm text-ctp-subtext0">
        <a href="/" class="font-medium text-ctp-mauve hover:underline">← Back to library</a>
      </p>
    </div>
  </main>
</Layout>

<script>
  const input = document.getElementById('file-input') as HTMLInputElement
  const label = document.getElementById('file-name') as HTMLParagraphElement
  const form = document.getElementById('upload-form') as HTMLFormElement
  const btn = document.getElementById('submit-btn') as HTMLButtonElement

  input?.addEventListener('change', () => {
    const name = input.files?.[0]?.name
    if (name) {
      label.textContent = name
      label.classList.remove('hidden')
    }
  })

  form?.addEventListener('submit', () => {
    btn.disabled = true
    btn.textContent = 'Uploading…'
  })
</script>
